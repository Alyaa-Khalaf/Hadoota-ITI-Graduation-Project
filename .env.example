# ===== Server =====
NODE_ENV=development
PORT=5000
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

# ===== Database / Cache =====
MONGODB_URI=mongodb://localhost:27017/hadoota
REDIS_URL=redis://localhost:6379

# ===== Auth =====
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_EXPIRES_IN=7d

# ===== Payments (Paymob) =====
# Get these from your Paymob dashboard (Settings → Account Info / Integrations).
# Test and Live keys must match the integration ID's mode.
PAYMOB_BASE_URL=https://accept.paymob.com
PAYMOB_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
PAYMOB_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
PAYMOB_HMAC_SECRET=xxxxxxxxxxxxxxxx
PAYMOB_INTEGRATION_ID_CARD=123456

# ===== AI providers =====
GEMINI_API_KEY=
GEMINI_STORY_MODEL=
GEMINI_IMAGE_MODEL=
GOOGLE_API_KEY=
OPENAI_API_KEY=
OPENAI_STORY_MODEL=
OPENAI_IMAGE_MODEL=

# ===== Voice (ElevenLabs) =====
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=

# ===== Email =====
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
EMAIL_FROM=

# ===== Web Push (VAPID) =====
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
