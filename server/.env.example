# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://...

# JWT
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI
OPENAI_API_KEY=your_openai_key
OPENAI_STORY_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3

# Google Gemini
GOOGLE_API_KEY=your_google_gemini_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_voice_id
ELEVENLABS_MODEL=eleven_multilingual_v2

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET_NAME=hadoota-media
AWS_REGION=us-east-1

# Redis
REDIS_URL=your_upstash_redis_url

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_webhook_secret
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_FAMILY=price_xxxxxxxxxxxxx
STRIPE_PRICE_SCHOOLS=price_xxxxxxxxxxxxx

# SendGrid
SENDGRID_API_KEY=your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Client URL (for email links & CORS)
CLIENT_URL=http://localhost:3000

# Web Push (VAPID keys — run: node src/scripts/generateVapidKeys.js)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:support@hadoota.com

# Mixpanel
MIXPANEL_TOKEN=your_mixpanel_token
